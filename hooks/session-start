#!/usr/bin/env bash
set -euo pipefail

# config existence check only. `.claude/workflow-config.yml` is the legacy file
# that session-start auto-migrates to `.claude/config.yml`; treat either as a
# signal that the project is already configured.
if [ -f ".claude/config.yml" ] || [ -f ".claude/workflow-config.yml" ]; then
  echo '{}'
  exit 0
fi

context="atdd-kit is not configured. The session-start skill will auto-detect your platform and set up the project."

escape_for_json() {
  local s="$1"
  s="${s//\\/\\\\}"
  s="${s//\"/\\\"}"
  s="${s//$'\n'/\\n}"
  s="${s//$'\r'/\\r}"
  s="${s//$'\t'/\\t}"
  printf '%s' "$s"
}

escaped_context=$(escape_for_json "$context")

if [ -n "${CURSOR_PLUGIN_ROOT:-}" ]; then
  printf '{\n  "additional_context": "%s"\n}\n' "$escaped_context"
elif [ -n "${CLAUDE_PLUGIN_ROOT:-}" ]; then
  printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "SessionStart",\n    "additionalContext": "%s"\n  }\n}\n' "$escaped_context"
else
  printf '{\n  "additional_context": "%s"\n}\n' "$escaped_context"
fi

exit 0
